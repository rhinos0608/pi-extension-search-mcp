{
  "name": "@search-mcp/pi-extension",
  "version": "0.1.0",
  "description": "Pi extension exposing search, crawl, browse, research, and GitHub tools.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "pi-extension-search": "./bin/pi-extension-search.mjs"
  },
  "files": [
    "bin/",
    "src/*.ts",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "cli": "node --import tsx src/cli.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.21.0",
    "typebox": "^1.3.2"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.10",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
