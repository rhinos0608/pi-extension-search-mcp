# Pi-Atlas environment variables
# Copy to .env or set in your shell profile (~/.zshrc, ~/.bashrc)
# Process environment wins over .env

# ── API keys (optional — zero-config DuckDuckGo works without any) ──

# GITHUB_TOKEN="ghp_..."
# EXA_API_KEY="..."
# BRAVE_API_KEY="..."
# TAVILY_API_KEY="..."
# YOUTUBE_API_KEY="..."
# REDDIT_CLIENT_ID="..."
# REDDIT_CLIENT_SECRET="..."
# REDDIT_USER_AGENT="pi-atlas/0.1"
# SEARXNG_BASE_URL="https://searxng.example.com"
# NITTER_BASE_URL="https://nitter.example.com"
# LISTENNOTES_API_KEY="..."
# PRODUCTHUNT_API_TOKEN="..."
# PATENTSVIEW_API_KEY="..."

# ── Backend control ──

# PI_SEARCH_WEB_BACKENDS="duckduckgo,brave,searxng"
# PI_SEARCH_BROWSER_BACKEND="cdp"
# PI_SEARCH_BROWSER_ALLOW_SENSITIVE="1"
# PI_SEARCH_DESKTOP_AUTOMATION="1"

# ── Bootstrap ──

# PI_SEARCH_BOOTSTRAP="off"
# PI_SEARCH_AUTO_INSTALL="0"
# PI_SEARCH_ALLOW_INSTALL="0"
# PI_SEARCH_AUTO_COOKIES="off"
# PI_SEARCH_BROWSER_AUTOMATION="0"

# ── Output ──

# PI_SEARCH_MAX_TOOL_OUTPUT_CHARS="60000"

# ── State ──

# PI_SEARCH_STATE_DIR="$HOME/.pi-atlas"

# ── Cookies ──

# PI_SEARCH_COOKIE_BROWSER="chrome"
# PI_SEARCH_COOKIE_STALE_MS="43200000"

# ── CDP rollback ──

# BROWSER_CDP_ENDPOINT="http://127.0.0.1:9222"

# ── Cua Driver (desktop) ──

# CUA_DRIVER_PATH="/usr/local/bin/cua-driver"
