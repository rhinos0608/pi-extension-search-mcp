# Pi-Atlas environment variables
# Copy to .env or set in your shell profile (~/.zshrc, ~/.bashrc)
# Process environment wins over .env

# ── API keys (optional — zero-config DuckDuckGo works without any) ──

# GITHUB_TOKEN="ghp_..."
# EXA_API_KEY="..."
# BRAVE_API_KEY="..."
# TAVILY_API_KEY="..."
# YOUTUBE_API_KEY="..."
# REDDIT_CLIENT_ID="..."
# REDDIT_CLIENT_SECRET="..."
# REDDIT_USER_AGENT="pi-atlas/0.1"
# SEARXNG_BASE_URL="https://searxng.example.com"
# NITTER_BASE_URL="https://nitter.example.com"
# LISTENNOTES_API_KEY="..."
# PRODUCTHUNT_API_TOKEN="..."
# PATENTSVIEW_API_KEY="..."

# ── Embedding sidecar (powers GitHub code_search semantic retrieval) ──
# When configured, github code_search uses AST-aware embeddings + tree-sitter
# for semantic code retrieval. Without these, code_search falls back to
# lexical GitHub code search.

# EMBEDDING_SIDECAR_PROVIDER="openai"
# EMBEDDING_SIDECAR_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_SIDECAR_API_TOKEN="sk-..."
# EMBEDDING_SIDECAR_DIMENSIONS="1536"
# EMBEDDING_SIDECAR_CODE_MODEL="text-embedding-3-small"

# ── LLM (used by deep research and other LLM-backed features) ──

# SEARCH_LLM_PROVIDER="openai"
# SEARCH_LLM_API_TOKEN="sk-..."
# SEARCH_LLM_BASE_URL="https://api.openai.com/v1"

# ── Deep research ──

# DEEP_RESEARCH_BASE_URL="https://..."
# DEEP_RESEARCH_WORKER_BASE_URL="https://..."
# DEEP_RESEARCH_API_TOKEN="..."
# DEEP_RESEARCH_MODEL="gpt-4o"
# DEEP_RESEARCH_WORKER_MODEL="gpt-4o-mini"

# ── Crawl4AI (alternative page reader backend) ──

# CRAWL4AI_BASE_URL="https://..."
# CRAWL4AI_API_TOKEN="..."

# ── Ollama search (local LLM-backed search) ──

# OLLAMA_SEARCH_BASE_URL="http://localhost:11434"
# OLLAMA_SEARCH_API_KEY="..."

# ── Backend control ──

# PI_SEARCH_WEB_BACKENDS="duckduckgo,brave,searxng"
# PI_SEARCH_BROWSER_BACKEND="cdp"
# PI_SEARCH_BROWSER_ALLOW_SENSITIVE="1"
# PI_SEARCH_DESKTOP_AUTOMATION="1"

# ── Bootstrap ──

# PI_SEARCH_BOOTSTRAP="off"
# PI_SEARCH_AUTO_INSTALL="0"
# PI_SEARCH_ALLOW_INSTALL="0"
# PI_SEARCH_AUTO_COOKIES="off"
# PI_SEARCH_BROWSER_AUTOMATION="0"

# ── Output ──

# PI_SEARCH_MAX_TOOL_OUTPUT_CHARS="60000"

# ── State ──

# PI_SEARCH_STATE_DIR="$HOME/.pi-atlas"

# ── Cookies ──

# PI_SEARCH_COOKIE_BROWSER="chrome"
# PI_SEARCH_COOKIE_STALE_MS="43200000"

# ── CDP rollback ──

# BROWSER_CDP_ENDPOINT="http://127.0.0.1:9222"

# ── Cua Driver (desktop) ──

# CUA_DRIVER_PATH="/usr/local/bin/cua-driver"
